# ==== Shopify ====
# After creating the 3 products in Shopify admin, paste default variant IDs here.
NEXT_PUBLIC_SHOPIFY_DOMAIN=yourshop.myshopify.com
NEXT_PUBLIC_SHOPIFY_VARIANT_STARTER=0000000000000
NEXT_PUBLIC_SHOPIFY_VARIANT_PDF=0000000000000
NEXT_PUBLIC_SHOPIFY_VARIANT_FULL=0000000000000

# Webhook (Settings > Notifications > Webhooks > Order payment)
SHOPIFY_WEBHOOK_SECRET=replace_me

# ==== JWT (for unlock magic links) ====
# Generate with: openssl rand -base64 48
JWT_SECRET=generate_a_long_random_string_at_least_32_bytes

# ==== Dev-only unlock without JWT (local dev only) ====
# Set to 'true' on preview deploys to enable /api/unlock?tier=full
NEXT_PUBLIC_DEV_UNLOCK=true

# ==== Email (Resend recommended) ====
RESEND_API_KEY=re_...
EMAIL_FROM=Remedia <hello@yourdomain.com>

# ==== NextAuth / Auth.js ====
NEXTAUTH_SECRET=generate_another_random_string
NEXTAUTH_URL=http://localhost:3000

# SMTP for magic-link sign-in (alternative: use Resend SMTP)
EMAIL_SERVER_HOST=smtp.resend.com
EMAIL_SERVER_PORT=587
EMAIL_SERVER_USER=resend
EMAIL_SERVER_PASSWORD=your_resend_api_key

# ==== Supabase (accounts + favorites) ====
SUPABASE_URL=https://xxxx.supabase.co
SUPABASE_SERVICE_ROLE_KEY=eyJ...
NEXT_PUBLIC_SUPABASE_URL=https://xxxx.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJ...

# ==== Sentry (error monitoring) ====
# Get DSN from https://sentry.io/settings/projects/
NEXT_PUBLIC_SENTRY_DSN=https://xxxx@o1234.ingest.sentry.io/12345
SENTRY_DSN=https://xxxx@o1234.ingest.sentry.io/12345
